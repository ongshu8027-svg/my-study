package view;

import domain.Book;   // 데이터 전송 및 생성을 위해 Book 클래스를 불러옵니다.
import domain.Member; // 데이터 전송 및 생성을 위해 Member 클래스를 불러옵니다.
import controller.LibraryController; // 사용자의 명령을 전달할 비즈니스 로직 제어 부품을 불러옵니다.
import java.util.List;
import java.util.Scanner;

public class LibraryConsoleView {
    // LibraryController를 필드로 가지고 있어야 사용자의 요청에 따라 실제 연산 기능을 호출할 수 있습니다.
    private LibraryController controller; // 컨트롤러 부품을 담을 참조 변수입니다.
    private Scanner scanner = new Scanner(System.in); // 키보드 입력을 편리하게 받기 위한 자바 기본 스캐너 객체입니다.

    // [생성자] 의존성 주입(DI) 방식으로, 외부에서 조립된 컨트롤러 엔진을 받아와 연결합니다.
    public LibraryConsoleView(LibraryController controller) {
        this.controller = controller; // 전달받은 컨트롤러 엔진을 뷰 내부 변수에 장착합니다.
    }

    // [시스템 시작 메서드] Run 클래스에서 호출되어 전체 메뉴 루프를 무한히 구동하는 메인 제어 기둥입니다.
    public void start() {
        // 프로그램이 정상 구동되었음을 알리는 부팅 알림 메시지를 화면에 찍어줍니다.
        printMessage("도서관 시스템 가동 (사용 가능 ID: M001, M002 등 자유롭게 등록하세요!)");

        // 사용자가 0번을 눌러 명시적으로 종료하기 전까지 계속 메뉴판을 띄우는 무한 반복문입니다.
        while (true) {
            int menu = showMainMenu(); // 화면에 메뉴판을 찍고 사용자가 선택한 숫자를 입력받아 menu 변수에 저장합니다.
            
            if (menu == 1) { // [1번 선택]: 도서 등록
                Book book = inputBookInfo(); // 키보드로 도서 번호와 제목을 입력받아 하나의 Book 객체로 생성해 옵니다.
                controller.registerBook(book);   // 생성한 도서 객체를 컨트롤러의 장부(List)에 등록하라고 넘겨줍니다.
                printMessage("도서가 등록되었습니다."); // 등록 처리가 완료되었음을 사용자에게 친절히 알립니다.
                
            } else if (menu == 2) { // [2번 선택]: 도서 현황 전체 조회
                printBookList(controller.getBookList()); // 컨트롤러에게 현재 저장된 도서 전체 리스트를 요청하여 받아온 뒤 화면에 표 형태로 출력합니다.
                
            } else if (menu == 3) { // [3번 선택]: 도서 대출
                String mId = inputFieldInfo("대출할 회원 ID"); // 범용 입력창을 통해 대출 신청자의 회원 ID를 입력받습니다.
                String bId = inputFieldInfo("대출할 도서 번호"); // 범용 입력창을 통해 빌려 가고자 하는 책 번호를 입력받습니다.
                
                // 컨트롤러에게 대출 처리 로직을 지시하고 결과값(true/false)을 조건문으로 판단합니다.
                if (controller.processBorrow(mId, bId)) {
                    printMessage("대출 성공!"); // 정상적으로 대출 처리가 완료되면 성공 메시지를 띄웁니다.
                } else {
                    printMessage("대출 실패! (ID 오류, 존재하지 않는 도서, 혹은 3권 초과 대출 상태 확인)"); // 조건에 안 맞아 튕기면 사유를 알립니다.
                }
                
            } else if (menu == 4) { // [4번 선택]: 도서 반납 
                String bId = inputFieldInfo("반납할 도서 번호"); // 반납할 책의 고유 번호를 입력받아 bId 변수에 저장합니다.
                
                // 컨트롤러에게 해당 책 번호의 반납 처리를 요청하고 그 성공 유무를 판단합니다.
                if (controller.processReturn(bId)) {
                    printMessage("반납 완료되었습니다."); // 성공적으로 장부가 차감되고 책 상태가 리셋되면 완료 메시지를 출력합니다.
                } else {
                    printMessage("반납 실패! (대출 중인 올바른 도서 번호가 아닙니다.)"); // 애초에 대출 안 된 책이거나 번호가 틀리면 실패를 띄웁니다.
                }
                
            } else if (menu == 5) { // [5번 선택]: 도서 삭제
                String bId = inputFieldInfo("삭제할 도서 번호"); // 도서관 장부에서 지워버릴 책 번호를 입력받습니다.
                
                // 컨트롤러에 도서 삭제 연산을 요청하고 검증 결과에 따라 처리합니다.
                if (controller.deleteBook(bId)) {
                    printMessage("도서가 정상적으로 삭제되었습니다."); // 대출 중이 아닌 도서여서 삭제가 완료되면 알림을 보냅니다.
                } else {
                    printMessage("삭제 실패! (대출 중인 도서는 반납 전까지 지울 수 없습니다.)"); // 누군가 빌려 간 책이라면 경고를 띄우며 차단합니다.
                }
                
            } else if (menu == 6) { // [6번 선택]: 회원 등록
                Member member = inputMemberInfo(); // 키보드로 새로운 회원의 ID와 이름을 입력받아 한 명의 Member 객체로 조립해 옵니다.
                // 컨트롤러 장부(Map)에 새 회원 등록을 지시하고 ID 중복 여부에 따른 결과를 받습니다.
                if (controller.registerMember(member)) {
                    printMessage("회원 등록이 완료되었습니다."); // 겹치는 ID가 없어서 맵에 안전하게 저장이 완료되면 성공 알림을 보냅니다.
                } else {
                    printMessage("등록 실패! (이미 존재하는 회원 ID입니다.)"); // 기존에 이미 등록된 동일 ID가 발견되면 등록을 거부합니다.
                }

            } else if (menu == 7) { // [7번 선택]: 회원 탈퇴
                String mId = inputFieldInfo("삭제할 회원 ID"); // 도서관 장부에서 영구 제명(삭제) 처리할 회원 ID를 입력받습니다.
                // 컨트롤러에게 회원 탈퇴 연산을 지시하고 검증 로직 통과 여부를 판단합니다.
                if (controller.deleteMember(mId)) {
                    printMessage("회원 정보가 성공적으로 삭제되었습니다."); // ID가 존재하고 빌려 간 책도 없는 깨끗한 상태면 정상 삭제 처리합니다.
                } else {
                    printMessage("삭제 실패! (존재하지 않는 ID이거나, 아직 대출 중인 도서가 있는 회원은 삭제할 수 없습니다.)"); // 먹튀 방지용 예외 안내입니다.
                }

            } else if (menu == 0) { // [0번 선택]: 종료 및 데이터백업
                controller.saveToFile(); // 프로그램이 아예 꺼지기 바로 직전, 메모리에 있던 모든 리스트와 맵 데이터를 하드디스크(.dat) 파일에 백업합니다.
                printMessage("데이터를 안전하게 저장하고 프로그램을 완전히 종료합니다."); // 종료 안내 메시지를 띄웁니다.
                break; // 무한 반복문(while)의 굴레를 깨부수고 나갑니다. 이로써 start() 메서드가 끝나고 메인 프로그램이 종료됩니다.
                
            } else { 
                printMessage("잘못된 메뉴 번호입니다. 0번에서 7번 사이를 입력하세요."); // 번호판 범위를 벗어난 이상한 숫자를 쳤을 때 예외 방어 조치입니다.
            }
        }
    }

    // [메인 메뉴 화면 출력] 콘솔창에 고를 수 있는 번호판을 텍스트로 예쁘게 그려주는 함수입니다.
    public int showMainMenu() {
        System.out.println("\n===== 도서관 관리 시스템 =====");
        System.out.println("1. 도서 등록 ");
        System.out.println("2. 도서 현황 조회 ");
        System.out.println("3. 도서 대출 ");
        System.out.println("4. 도서 반납 ");
        System.out.println("5. 도서 삭제 ");
        System.out.println("6. 신규 회원 등록");
        System.out.println("7. 기존 회원 삭제");
        System.out.println("0. 프로그램 종료 및 저장");
        System.out.print("메뉴 선택: ");
        int selected = scanner.nextInt(); // 사용자가 친 숫자 메뉴 번호를 읽어옵니다.
        scanner.nextLine(); // 공통 버퍼 비우기 기능입니다. (nextInt()가 버퍼에 남겨둔 엔터('\n') 키를 청소하여 다음 입력이 무시당하는 것을 방지합니다.)
        return selected; // 읽어온 메뉴 번호를 제어 제어부(start 조건문)로 반환합니다.
    }

    // [도서 등록 입력 화면] 1번을 눌렀을 때 작동하는 전용 책 정보 입력 창입니다.
    public Book inputBookInfo() {
        System.out.print("등록할 도서 번호: ");
        String id = scanner.nextLine(); // 사용자가 입력한 책 번호를 읽어 문자열 변수 id에 담습니다.
        System.out.print("등록할 도서 제목: ");
        String title = scanner.nextLine(); // 사용자가 입력한 책 제목을 읽어 문자열 변수 title에 담습니다.
        return new Book(id, title); // 입력받은 두 재료를 엮어 파릇파릇한 새 Book 객체를 생성하여 호출한 곳으로 보냅니다.
    }

    // [회원 등록 입력 화면] 6번을 눌렀을 때 작동하는 전용 회원 정보 입력 창입니다.
    public Member inputMemberInfo() {
        System.out.print("등록할 회원 ID: ");
        String id = scanner.nextLine(); // 등록하려는 신규 회원의 ID를 입력받습니다.
        System.out.print("등록할 회원 이름: ");
        String name = scanner.nextLine(); // 등록하려는 신규 회원의 이름을 입력받습니다.
        return new Member(id, name); // 재료들을 모아 가입 대기용 Member 객체를 새로 조립하여 리턴합니다.
    }

    // [공통 문자열 입력 화면] 가독성을 높이기 위해 단순 한 줄짜리 키워드 입력을 통합 처리해 주는 유용한 범용 입력 메서드입니다.
    public String inputFieldInfo(String msg) {
        System.out.print(msg + " 입력: "); // 매개변수로 넘어온 안내용 메시지(msg)를 동적으로 콘솔에 띄워줍니다.
        return scanner.nextLine(); // 입력창을 열어 즉시 사용자가 적은 문자열 한 줄을 읽어서 그대로 돌려줍니다.
    }

    // [도서 현황 출력 화면] 2번을 눌렀을 때 작동하며 데이터들의 현재 장부 상태를 정돈된 표 양식으로 시각화합니다.
    public void printBookList(List<Book> bookList) {
        System.out.println("\n[도서 현황 목록]");
        System.out.println("-------------------------------------------------------");
        System.out.println("도서번호\t| 제목\t\t| 대출여부\t| 대출자ID\t");
        System.out.println("-------------------------------------------------------");
        
        if (bookList.isEmpty()) {
            System.out.println("등록된 도서가 존재하지 않습니다."); // 만약 도서관에 보관된 책 리스트의 사이즈가 0이면 비어있다고 경고 문구를 띄웁니다.
        } else {
            // 리스트에 책이 한 권이라도 들어있다면, 향상된 for문을 돌려 리스트의 맨 앞 책부터 맨 뒤 책까지 하나씩 차례대로 꺼내 b 변수에 담습니다.
            for (Book b : bookList) {
                // 삼항 연산자를 사용해 대출중 여부 상태값(true/false)에 따라 화면에 출력할 한글 단어를 가려 뽑습니다.
                String status = b.isBorrowed() ? "대출중" : "대출가능";
                // 삼항 연산자를 사용해 대출자 회원 ID 데이터가 존재하면 해당 ID를, 비어있으면 깔끔하게 하이픈(-) 기호로 치환합니다.
                String borrower = b.getBorrowerId() != null ? b.getBorrowerId() : "-";
                // 날짜 정보도 마찬가지로 비어있지 않으면 문자열로 변환하고 없으면 하이픈 기호 처리를 해줍니다.
                String date = b.getDueDate() != null ? b.getDueDate().toString() : "-";
                
                // 가독성을 극대화하기 위해 각 책 정보 사이에 탭('\t') 기호와 이정표 줄을 섞어서 한 줄의 이쁜 데이터 행으로 콘솔창에 뿌려줍니다.
                System.out.println(b.getBookId() + "\t| " + b.getTitle() + "\t| " + status + "\t| " + borrower + "\t| " + date);
            }
        }
        System.out.println("-------------------------------------------------------");
    }

    // [알림 메시지 출력 함수] 귀찮게 System.out.println을 매번 치지 않고 뷰 안에서 한 줄로 간결하게 알림창을 띄우는 편의용 공용 메서드입니다.
    public void printMessage(String msg) {
        System.out.println(msg); // 매개변수로 전달된 알림 문자열 한 줄을 그대로 화면에 노출합니다.
    }
}
