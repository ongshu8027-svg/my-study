package main;

import controller.LibraryController; // 핵심 조작 엔진을 메모리에 올리기 위해 임포트합니다.
import view.LibraryConsoleView;     // 첫 안내 화면 콘솔 창을 실행하기 위해 임포트합니다.

public class Run {
    // 자바 가상머신(JVM)이 프로그램을 켤 때 제일 먼저 손을 잡고 실행하는 전역 유일의 진입 스태틱 메인 메서드입니다.
    public static void main(String[] args) {
        
        // 1. 도서관 전체 비즈니스 연산 장부 처리를 총괄 담당하는 핵심 엔진 부품인 컨트롤러 인스턴스를 메모리에 새로 구축(생성)합니다.
        LibraryController controller = new LibraryController();
        
        // 2. 사용자용 입출력 콘솔 화면 부품(View) 객체를 생성합니다. 이때 생성자 인자값으로 위에서 조립한 컨트롤러 엔진 주소를 주입(DI)하여 둘을 단단하게 결합시킵니다.
        LibraryConsoleView view = new LibraryConsoleView(controller);

        // 3. 프로그램이 완전히 켜지자마자 컴퓨터 하드디스크 깊숙이 잠들어 있는 과거 데이터 파일("library_data.dat")을 찾아서 메모리 장부 상으로 완벽하게 원복/로드해 옵니다.
        controller.loadFromFile();

        // 4. 모든 조립과 복구 작업이 무사히 마감되었으므로, 화면단 부품의 start() 메서드를 힘차게 호출해 무한 메뉴 대기 화면 루프 속으로 진입시킵니다.
        view.start();
    }
}
