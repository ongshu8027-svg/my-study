public class Run {
    // 프로그램이 시작하는 진짜 진입점 주 메인 메서드
    public static void main(String[] args) {
        // 핵심 부품인 컨트롤러 엔진과 콘솔 화면 뷰 객체를 각각 1개씩 생성해 둡니다.
        LibraryController controller = new LibraryController();
        LibraryConsoleView view = new LibraryConsoleView();

        // 1. 프로그램이 부팅되자마자 하드디스크 파일에서 과거 데이터를 싹 긁어 모아 복구합니다.
        controller.loadFromFile();
        
        // 2. 만약 처음 실행했거나 파일이 없어서 불러온 회원 정보 수(Map의 크기)가 0명이라면, 
        // 테스트를 바로 진행할 수 있게 고정 아이디 M001과 M002 회원 2명을 강제로 엔진 장부에 심어줍니다.
        if (controller.getMemberMapSize() == 0) {
            controller.registerMember(new Member("M001", "홍길동"));
            controller.registerMember(new Member("M002", "김철수"));
        }

        // 시스템 시작을 알리는 웰컴 문구 출력
        view.printMessage("도서관 시스템 가동 (사용 가능 ID: M001, M002)");

        // 3. 사용자가 메뉴에서 0번을 눌러 빠져나가기 전까지 무한히 계속 뺑뺑이 루프를 돌립니다.
        while (true) {
            int menu = view.showMainMenu(); // 화면에 메뉴판을 띄우고 사용자가 고른 숫자를 받아옴

            if (menu == 1) { // [1번 선택]: 도서 등록 프로세스
                Book book = view.inputBookInfo(); // 화면에서 키보드로 입력받아 만들어진 책 객체를 받아서
                controller.registerBook(book);    // 컨트롤러 장부 상자(List)에 정식 등록시킵니다.
                view.printMessage("도서가 등록되었습니다.");
                
            } else if (menu == 2) { // [2번 선택]: 도서 현황 전체 조회 프로세스
                // 컨트롤러에서 최신 책 목록(List)을 받아와서, 뷰 화면단에 통째로 넘겨줘서 찍게 만듭니다.
                view.printBookList(controller.getBookList());
                
            } else if (menu == 3) { // [3번 선택]: 도서 대출 프로세스
                String mId = view.inputDeleteInfo("대출할 회원 ID"); // 예: M001 입력받음
                String bId = view.inputDeleteInfo("대출할 도서 번호"); // 예: B001 입력받음
                
                // 컨트롤러 엔진에게 대출 로직을 계산하라고 던져주고 결과가 성공(true)이냐 실패(false)냐에 따라 알림 처리
                if (controller.processBorrow(mId, bId)) {
                    view.printMessage("대출 성공!");
                } else {
                    view.printMessage("대출 실패! (ID 오류 혹은 3권 초과 대출 상태 확인)");
                }
                
            } else if (menu == 4) { // [4번 선택]: 도서 반납 프로세스
                String bId = view.inputDeleteInfo("반납할 도서 번호"); // 예: B001 입력받음
                
                // 컨트롤러 엔진에게 반납 연산을 시키고 결과를 받습니다.
                if (controller.processReturn(bId)) {
                    view.printMessage("반납 완료되었습니다.");
                } else {
                    view.printMessage("반납 실패! (대출 중인 올바른 도서 번호가 아닙니다.)");
                }
                
            } else if (menu == 5) { // [5번 선택]: 도서 삭제 프로세스
                String bId = view.inputDeleteInfo("삭제할 도서 번호");
                
                // 컨트롤러 엔진에게 리스트에서 해당 책을 지우라고 시킵니다.
                if (controller.deleteBook(bId)) {
                    view.printMessage("도서가 정상적으로 삭제되었습니다.");
                } else {
                    view.printMessage("삭제 실패! (대출 중인 도서는 반납 전까지 지울 수 없습니다.)");
                }
                
            } else if (menu == 0) { // [0번 선택]: 종료 및 데이터 영구 백업 프로세스
                controller.saveToFile(); // 리스트와 맵의 장부 데이터를 파일로 안전하게 백업 저장합니다.
                view.printMessage("데이터를 안전하게 저장하고 프로그램을 완전히 종료합니다.");
                break; // 무한 반복 while 루프를 깨부수고 탈출하여 main 메서드를 끝냅니다.
                
            } else { // 엉뚱한 숫자를 쳤을 때 예외 처리
                view.printMessage("잘못된 메뉴 번호입니다. 0번에서 5번 사이를 입력하세요.");
            }
        }
    }
}
